// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TRESORIER
  VALIDATEUR
  OBSERVATEUR
}

enum StatutMembre {
  ACTIF
  SUSPENDU
  INVITE
}

enum StatutDepense {
  BROUILLON
  EN_ATTENTE
  APPROUVEE
  REJETEE
  CLOTUREE
}

enum DecisionVote {
  APPROUVE
  REJETE
  ABSTENTION
}

enum TypePiece {
  DEVIS
  FACTURE
  PHOTO
}

enum TypeChat {
  DEPENSE
  GENERAL
}

// ─── TABLES ──────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  nom             String
  prenom          String
  email           String   @unique
  motDePasseHash  String
  telephone       String?
  avatarUrl       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Relations
  memberships     Membre[]
  depensesProposees Depense[] @relation("DepenseProposePar")
  votes           Validation[]
  messages        Message[]
  entreesEnregistrees Entree[]
  piecesJointes   PieceJointe[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  organisationsCreees Organisation[]
}

model Organisation {
  id                  String   @id @default(uuid())
  nom                 String
  description         String?
  logoUrl             String?
  slug                String   @unique
  seuilValidation     Int      @default(2)
  seuilMontantAlerte  Decimal  @default(0) @db.Decimal(15, 2)
  createdAt           DateTime @default(now())

  createurId  String
  createur    User   @relation(fields: [createurId], references: [id])

  membres     Membre[]
  caisses     Caisse[]
  chats       Chat[]
  auditLogs   AuditLog[]
}

model Membre {
  id             String       @id @default(uuid())
  role           Role
  statut         StatutMembre @default(INVITE)
  joinedAt       DateTime     @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  invitePar      String?

  @@unique([userId, organisationId])
}

model Caisse {
  id          String   @id @default(uuid())
  nom         String
  description String?
  soldeActuel Decimal  @default(0) @db.Decimal(15, 2)
  devise      String   @default("MGA")
  estPublique Boolean  @default(true)
  createdAt   DateTime @default(now())

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])

  entrees  Entree[]
  depenses Depense[]
}

model Entree {
  id           String   @id @default(uuid())
  montant      Decimal  @db.Decimal(15, 2)
  source       String
  donateurNom  String?
  dateEntree   DateTime @default(now())
  hash         String   @unique

  caisseId       String
  caisse         Caisse @relation(fields: [caisseId], references: [id])

  enregistrePar  String
  enregistreur   User   @relation(fields: [enregistrePar], references: [id])
}

model Depense {
  id              String        @id @default(uuid())
  titre           String
  description     String?
  montantDemande  Decimal       @db.Decimal(15, 2)
  montantReel     Decimal?      @db.Decimal(15, 2)
  statut          StatutDepense @default(BROUILLON)
  createdAt       DateTime      @default(now())
  clotureAt       DateTime?
  hash            String        @unique
  hashPrecedent   String?

  caisseId    String
  caisse      Caisse @relation(fields: [caisseId], references: [id])

  proposePar  String
  proposeur   User   @relation("DepenseProposePar", fields: [proposePar], references: [id])

  validations   Validation[]
  piecesJointes PieceJointe[]
  recu          Recu?
  chat          Chat?
}

model Validation {
  id            String       @id @default(uuid())
  decision      DecisionVote
  commentaire   String?
  voteAt        DateTime     @default(now())
  signatureHash String

  depenseId     String
  depense       Depense @relation(fields: [depenseId], references: [id])

  validateurId  String
  validateur    User    @relation(fields: [validateurId], references: [id])

  @@unique([depenseId, validateurId])
}

model PieceJointe {
  id         String    @id @default(uuid())
  url        String
  type       TypePiece
  uploadedAt DateTime  @default(now())

  depenseId  String
  depense    Depense @relation(fields: [depenseId], references: [id])

  uploadedPar String
  uploader    User   @relation(fields: [uploadedPar], references: [id])
}

model Recu {
  id          String   @id @default(uuid())
  pdfUrl      String?
  qrCodeData  String
  hashFinal   String
  genereAt    DateTime @default(now())

  depenseId   String   @unique
  depense     Depense  @relation(fields: [depenseId], references: [id])
}

model Chat {
  id        String   @id @default(uuid())
  type      TypeChat
  createdAt DateTime @default(now())

  depenseId      String?      @unique
  depense        Depense?     @relation(fields: [depenseId], references: [id])

  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id])

  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  contenu   String
  sentAt    DateTime @default(now())
  isSysteme Boolean  @default(false)

  chatId    String
  chat      Chat   @relation(fields: [chatId], references: [id])

  auteurId  String
  auteur    User   @relation(fields: [auteurId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entiteType  String
  entiteId    String?
  details     Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  organisationId String
  organisation   Organisation @relation(fields: [organisationId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  titre     String
  contenu   String
  lu        Boolean  @default(false)
  lien      String?
  createdAt DateTime @default(now())

  userId  String
  user    User   @relation(fields: [userId], references: [id])
}